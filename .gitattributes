# 自动检测文本文件并规范化行尾为 LF
*       text=auto eol=lf

# 源码文件
*.zig   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf

# 构建配置
build.zig       text eol=lf
build.zig.zon   text eol=lf

# 二进制文件不转换
*.png   binary
*.jpg   binary
*.ico   binary
*.a     binary
*.o     binary
*.so    binary
*.dylib binary
*.dll   binary
*.exe   binary
